# 실제 값은 .env.local 에 두세요 (git 에 커밋되지 않음)
AUTH_SECRET=generate-with-openssl-rand-base64-33
AUTH_ADMIN_EMAIL=admin@boat.local
AUTH_ADMIN_PASSWORD=change-me

# --- 푸시 알림 (Pushover) ---
# https://pushover.net 에서 발급:
#   PUSHOVER_USER_KEY  = 대시보드 상단의 "Your User Key"
#   PUSHOVER_APP_TOKEN = "Create an Application/API Token" 으로 앱 만든 뒤의 API Token
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
# 상태 경고 시 자동 알림 (on 이면 활성, 목업 센서에선 스팸 주의)
ALERT_MONITOR=off
ALERT_MONITOR_LEVEL=alert
# 경고(alert)=긴급+사이렌+반복 / 주의(warning)=높음(경고음)
ALERT_SOUND=siren          # 경고 사운드 (Pushover 사운드명)
ALERT_RETRY=30             # 재전송 주기(초, 최소 30)
ALERT_EXPIRE=600           # 반복 만료(초) — 이 시간까지 확인 안 하면 정지
# WARN_SOUND=              # 주의 사운드 (비우면 기본)
# 알림에 넣을 앱 주소 (옵션)
# APP_BASE_URL=http://localhost:3000

# 활성 알림 채널 (기본 pushover)
NOTIFY_CHANNEL=pushover
